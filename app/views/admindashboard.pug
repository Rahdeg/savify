extends layout

block content
  section(class="space-y-6")
    h1(class="text-xl font-semibold") Admin Dashboard

    //- Summary stat cards
    .grid(class="grid-cols-2 sm:grid-cols-4 gap-4")
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Total Savings
        p(class="text-2xl font-bold") £#{stats.total_savings}
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Total Users
        p(class="text-2xl font-bold") #{stats.total_users}
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Total Goals
        p(class="text-2xl font-bold") #{stats.total_goals}
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Total Withdrawals
        p(class="text-2xl font-bold") #{stats.total_withdrawals}

    //- Goal status breakdown
    h2(class="text-lg font-semibold") Goals Breakdown
    .grid(class="grid-cols-2 sm:grid-cols-4 gap-4")
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Active
        p(class="text-2xl font-bold text-green-600") #{goalBreakdown.active_goals || 0}
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Completed
        p(class="text-2xl font-bold text-blue-600") #{goalBreakdown.completed_goals || 0}
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Withdrawn
        p(class="text-2xl font-bold text-yellow-600") #{goalBreakdown.withdrawn_goals || 0}
      .card.text-center
        p(class="text-slate-500 text-sm mb-1") Cancelled
        p(class="text-2xl font-bold text-red-600") #{goalBreakdown.cancelled_goals || 0}

    //- Monthly contributions
    h2(class="text-lg font-semibold") Monthly Contributions
    if monthlyContributions && monthlyContributions.length
      .table-wrap
        table.app-table
          thead
            tr
              th Month
              th Total Deposited
          tbody
            each row in monthlyContributions
              tr
                td #{row.month}
                td £#{row.total}
    else
      p No contribution data yet.

    //- Users table
    h2(class="text-lg font-semibold") Users
    if users && users.length
      .table-wrap
        table.app-table
          thead
            tr
              th Name
              th Email
              th Active Goals
              th Inactive Goals
              th Total Goals
          tbody
            each user in users
              tr
                td #{user.full_name}
                td #{user.email}
                td #{user.active_goals}
                td #{user.inactive_goals}
                td #{user.total_goals}
    else
      p No users registered yet.