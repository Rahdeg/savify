extends admin-layout

block content

  //- ── Page header ─────────────────────────────────────────────────────────
  .admin-topbar
    div
      h1.admin-page-title 📊 Admin Dashboard
      p.admin-page-subtitle Platform overview — all users, goals and savings

  //- ── Summary stat cards ──────────────────────────────────────────────────
  .admin-stats
    .admin-stat-card
      span.admin-stat-icon 💷
      p.admin-stat-label Total Savings
      p.admin-stat-value £#{stats.total_savings}
    .admin-stat-card
      span.admin-stat-icon 👤
      p.admin-stat-label Total Users
      p.admin-stat-value #{stats.total_users}
    .admin-stat-card
      span.admin-stat-icon 🎯
      p.admin-stat-label Total Goals
      p.admin-stat-value #{stats.total_goals}
    .admin-stat-card
      span.admin-stat-icon 💸
      p.admin-stat-label Total Withdrawals
      p.admin-stat-value #{stats.total_withdrawals}

  //- ── Goals breakdown ─────────────────────────────────────────────────────
  .admin-section
    .admin-section-header
      h2.admin-section-title 🎯 Goals Breakdown
    .admin-section-body
      .admin-breakdown
        .admin-breakdown-item
          span.admin-breakdown-num #{goalBreakdown.active_goals || 0}
          span.admin-breakdown-label Active
        .admin-breakdown-item
          span.admin-breakdown-num #{goalBreakdown.completed_goals || 0}
          span.admin-breakdown-label Completed
        .admin-breakdown-item
          span.admin-breakdown-num #{goalBreakdown.withdrawn_goals || 0}
          span.admin-breakdown-label Withdrawn
        .admin-breakdown-item
          span.admin-breakdown-num #{goalBreakdown.cancelled_goals || 0}
          span.admin-breakdown-label Cancelled

  //- ── Monthly contributions ───────────────────────────────────────────────
  .admin-section
    .admin-section-header
      h2.admin-section-title 📅 Monthly Contributions

    if monthlyContributions && monthlyContributions.length
      .table-wrap(style="border:none;border-radius:0;box-shadow:none;")
        table.app-table
          thead
            tr
              th Month
              th Total Deposited
          tbody
            each row in monthlyContributions
              tr
                td(style="font-weight:500;") #{row.month}
                td(style="font-weight:700;") £#{row.total}
    else
      .admin-section-body
        p(style="color:#94a3b8;font-size:0.875rem;text-align:center;padding:1rem 0;") No contribution data yet.

  //- ── Users table ─────────────────────────────────────────────────────────
  .admin-section
    .admin-section-header
      h2.admin-section-title 👤 Users

    if users && users.length
      .table-wrap(style="border:none;border-radius:0;box-shadow:none;")
        table.app-table
          thead
            tr
              th Name
              th Email
              th Active Goals
              th Inactive Goals
              th Total Goals
          tbody
            each user in users
              tr
                td(style="font-weight:600;") #{user.full_name}
                td(style="color:#6b7280;") #{user.email}
                td
                  span.badge.badge-green #{user.active_goals}
                td
                  span.badge.badge-grey #{user.inactive_goals}
                td(style="font-weight:600;") #{user.total_goals}
    else
      .admin-section-body
        p(style="color:#94a3b8;font-size:0.875rem;text-align:center;padding:1rem 0;") No users registered yet.
