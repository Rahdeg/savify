doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title} — Savify
    link(rel="stylesheet", href="/css/auth.css")
  body(class="auth-page")
    .auth-screen
      .auth-card

        //- ── Left panel: form ─────────────────────────────────────────────
        .auth-left
          p.auth-brand Sav#[span ify]
          block authContent

        //- ── Right panel: illustration ────────────────────────────────────
        .auth-right
          .auth-right-inner

            //- Savings jar SVG illustration
            svg.auth-illustration(
              viewBox="0 0 220 220"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            )
              //- Glow behind jar
              ellipse(cx="110" cy="215" rx="70" ry="12" fill="rgba(0,0,0,0.2)")

              //- Jar body
              path(
                d="M 42 108 Q 38 200 110 202 Q 182 200 178 108 Z"
                fill="rgba(255,255,255,0.18)"
                stroke="rgba(255,255,255,0.45)"
                stroke-width="1.5"
              )

              //- Coin stack layer 3 (bottom)
              ellipse(cx="110" cy="188" rx="52" ry="11" fill="rgba(251,191,36,0.75)")
              rect(x="58" y="162" width="104" height="26" fill="rgba(251,191,36,0.6)")
              ellipse(cx="110" cy="162" rx="52" ry="11" fill="rgba(253,211,77,0.9)")

              //- Coin stack layer 2
              ellipse(cx="110" cy="150" rx="42" ry="9" fill="rgba(251,191,36,0.75)")
              rect(x="68" y="128" width="84" height="22" fill="rgba(251,191,36,0.55)")
              ellipse(cx="110" cy="128" rx="42" ry="9" fill="rgba(253,224,77,0.9)")

              //- £ on top coin
              text(
                x="110" y="132"
                text-anchor="middle"
                font-size="15"
                font-weight="bold"
                fill="rgba(180,100,0,0.75)"
                font-family="Arial, sans-serif"
              ) £

              //- Jar neck
              rect(
                x="76" y="82"
                width="68" height="32"
                rx="7"
                fill="rgba(255,255,255,0.22)"
                stroke="rgba(255,255,255,0.4)"
                stroke-width="1.5"
              )

              //- Jar opening (top ellipse)
              ellipse(
                cx="110" cy="82"
                rx="36" ry="10"
                fill="rgba(255,255,255,0.3)"
                stroke="rgba(255,255,255,0.5)"
                stroke-width="1.5"
              )

              //- Lid cap
              rect(
                x="82" y="68"
                width="56" height="16"
                rx="6"
                fill="rgba(255,255,255,0.25)"
                stroke="rgba(255,255,255,0.4)"
                stroke-width="1.5"
              )

              //- Coin dropping into jar
              ellipse(
                cx="110" cy="48"
                rx="20" ry="7"
                fill="rgba(253,211,77,0.92)"
                stroke="rgba(217,119,6,0.4)"
                stroke-width="1"
              )
              text(
                x="110" y="52"
                text-anchor="middle"
                font-size="9"
                font-weight="bold"
                fill="rgba(146,64,14,0.9)"
                font-family="Arial, sans-serif"
              ) £

              //- Floating coin — left
              g(transform="rotate(-18, 60, 30)")
                ellipse(cx="60" cy="30" rx="15" ry="5.5" fill="rgba(253,211,77,0.78)")
                text(
                  x="60" y="34"
                  text-anchor="middle"
                  font-size="7"
                  font-weight="bold"
                  fill="rgba(146,64,14,0.85)"
                  font-family="Arial, sans-serif"
                ) £

              //- Floating coin — right top
              g(transform="rotate(15, 165, 22)")
                ellipse(cx="165" cy="22" rx="13" ry="4.5" fill="rgba(253,211,77,0.7)")
                text(
                  x="165" y="26"
                  text-anchor="middle"
                  font-size="6"
                  font-weight="bold"
                  fill="rgba(146,64,14,0.8)"
                  font-family="Arial, sans-serif"
                ) £

              //- Floating coin — right mid
              g(transform="rotate(-8, 178, 75)")
                ellipse(cx="178" cy="75" rx="12" ry="4" fill="rgba(253,211,77,0.65)")

              //- Floating coin — left mid
              g(transform="rotate(22, 32, 88)")
                ellipse(cx="32" cy="88" rx="13" ry="4.5" fill="rgba(253,211,77,0.65)")

              //- Growth sparkles
              circle(cx="28" cy="28" r="2.5" fill="rgba(255,255,255,0.65)")
              circle(cx="190" cy="18" r="2" fill="rgba(255,255,255,0.6)")
              circle(cx="198" cy="110" r="1.5" fill="rgba(255,255,255,0.5)")
              circle(cx="14" cy="140" r="2" fill="rgba(255,255,255,0.5)")
              circle(cx="148" cy="8" r="1.5" fill="rgba(255,255,255,0.55)")
              circle(cx="75" cy="15" r="1.5" fill="rgba(255,255,255,0.45)")

              //- Dashed growth trend line
              path(
                d="M 50 185 Q 70 165 95 155 Q 128 138 152 118"
                stroke="rgba(255,255,255,0.4)"
                stroke-width="2"
                fill="none"
                stroke-dasharray="5 3"
                stroke-linecap="round"
              )
              //- Arrow head on trend line
              polygon(
                points="150,112 160,120 154,124"
                fill="rgba(255,255,255,0.4)"
              )

            h3.auth-right-title Save smarter with Savify
            p.auth-right-text
              | Build your goals, track progress, and stay in control of your money.

            .auth-features
              .auth-feature-item
                .auth-feature-icon 🎯
                span Set personalised savings goals
              .auth-feature-item
                .auth-feature-icon 📈
                span Track your progress in real time
              .auth-feature-item
                .auth-feature-icon 🔒
                span Safe and secure contributions
