extends layout

block content
  - const arcR   = 38
  - const arcLen = Math.PI * arcR

  .page-header
    div
      h1.page-title 🎯 My Goals
      p.page-subtitle Set savings goals and track your progress towards achieving them.
    button.btn-primary(type="button" onclick="openCreateGoalModal()") + New Goal

  if fetchedGoals && fetchedGoals.length
    .goals-grid
      each goal in fetchedGoals
        - const pct    = goal.progressPercent
        - const filled = (pct / 100) * arcLen
        - const isDone = goal.goal_status === 'completed'
        - const badgeCls = isDone ? 'badge-blue' : goal.goal_status === 'active' ? 'badge-green' : 'badge-grey'

        article.goal-card
          .goal-card-top
            h3.goal-card-title #{goal.goal_title}
            span(class=`badge ${badgeCls}`) #{goal.goal_status}

          if goal.category_name
            p.goal-category 📂 #{goal.category_name}

          .goal-card-amounts
            span.goal-amount £#{parseFloat(goal.current_amount).toFixed(2)}
            span.goal-target of £#{parseFloat(goal.target_amount).toFixed(2)}

          //- Arc gauge with gradient
          .arc-wrap
            svg(viewBox="0 0 100 58" width="140" height="82")
              defs
                linearGradient(id=`grad-${goal.goal_id}` x1="0%" y1="0%" x2="100%" y2="0%")
                  stop(offset="0%" stop-color="#6366f1")
                  stop(offset="100%" stop-color="#8b5cf6")
              path(
                d="M 12,54 A 38,38 0 0,1 88,54"
                fill="none"
                stroke="#e5e7eb"
                stroke-width="10"
                stroke-linecap="round"
              )
              if pct > 0
                path(
                  d="M 12,54 A 38,38 0 0,1 88,54"
                  fill="none"
                  stroke=`url(#grad-${goal.goal_id})`
                  stroke-width="10"
                  stroke-linecap="round"
                  stroke-dasharray=`${filled} ${arcLen}`
                )
            p.arc-pct #{pct}%

          .goal-card-meta
            if goal.end_date
              p.goal-meta-item 📅 By #{formatDate(goal.end_date)}

          a.link-text(href=`/goals/${goal.goal_id}`) View details →

  else
    .dash-section(style="text-align:center;padding:3rem 1rem;")
      .goals-empty
        button.goals-empty-btn(type="button" onclick="openCreateGoalModal()") +
        p.goals-empty-text You haven't set any goals yet.
        button.btn-primary(type="button" onclick="openCreateGoalModal()") Create your first goal
