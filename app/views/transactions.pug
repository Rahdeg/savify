extends layout

block content
  .page-header
    div
      h1.page-title 📋 Transactions
      if profile && profile.full_name
        p.page-subtitle All transactions for #{profile.full_name}.

  if transactions && transactions.length
    .table-wrap
      table.app-table
        thead
          tr
            th Goal
            th Type
            th Amount
            th Status
            th Reference
            th Payment Method
            th Date
            th
        tbody
          each t in transactions
            tr
              td(style="font-weight:500;") #{t.goal_title}
              td #{t.transaction_type}
              td(style="font-weight:700;") £#{parseFloat(t.amount).toFixed(2)}
              td
                - const tBadge = t.transaction_status === 'completed' ? 'badge-green' : t.transaction_status === 'pending' ? 'badge-amber' : 'badge-grey'
                span(class=`badge ${tBadge}`) #{t.transaction_status}
              td
                span.mono #{t.transaction_reference || '—'}
              td #{t.method_name ? t.method_name + (t.provider_name ? ' · ' + t.provider_name : '') : '—'}
              td(style="color:#6b7280;font-size:0.8rem;") #{formatDateTime(t.transaction_date)}
              td
                a.link-text(href='/goals/' + t.goal_id) View →
  else
    .dash-section(style="text-align:center;padding:3rem 1rem;")
      p.empty-msg No transactions yet. Start saving towards a goal!
      a.btn-primary(href="/goals" style="display:inline-flex;margin-top:1rem;") View Goals
