extends layout

block content
  section(class='space-y-4')
    h1(class='text-xl font-semibold') Transactions

    if profile && profile.full_name
      p(class='text-slate-600') Here are all transactions for #{profile.full_name}.

    if transactions && transactions.length
      .table-wrap
        table.app-table
          thead
            tr
              th Goal
              th Type
              th Amount
              th Status
              th Reference
              th Payment Method
              th Date
              th Details
          tbody
            each t in transactions
              tr
                td #{t.goal_title}
                td #{t.transaction_type}
                td £#{t.amount}
                td #{t.transaction_status}
                td #{t.transaction_reference || 'N/A'}
                td #{t.method_name ? t.method_name + (t.provider_name ? ' - ' + t.provider_name : '') : 'N/A'}
                td #{t.transaction_date}
                td
                  a.link-text(href='/goals/' + t.goal_id) View goal
    else
      p No transactions found.