doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title}
    link(rel="stylesheet", href="/css/style.css")
    script(src="https://cdn.tailwindcss.com")

  body
    if sessionUser
      //- ── Sidebar + content ────────────────────────────────────────────
      .page-shell

        aside.sidebar
          .sidebar-brand Sav#[span ify]
          nav.sidebar-nav
            a.sidebar-link(href="/dashboard") Dashboard
            a.sidebar-link(href="/goals") Goals
            a.sidebar-link(href="/contributions") Savings
            a.sidebar-link(href="/transactions") Transactions
          .sidebar-footer
            a.sidebar-link.sidebar-link--danger(href="/auth/logout") Log out

        .page-content
          main
            block content
            include create-savings-goal

    else
      //- ── Guest header ─────────────────────────────────────────────────
      header(style="background:#fff;border-bottom:1px solid #e2e8f0;padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;")
        span(style="font-size:1.2rem;font-weight:800;color:#0f172a;") Sav#[span(style="color:#4f46e5") ify]
        nav(style="display:flex;gap:0.5rem;")
          a.nav-link(href="/auth/login") Login
          a.nav-link(href="/auth/register") Register

      main(style="max-width:900px;margin:0 auto;padding:1.5rem;")
        block content
        include create-savings-goal

    script(src="/js/modal.js")
