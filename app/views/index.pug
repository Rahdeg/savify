doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Savify — Save smarter, reach your goals
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin="")
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap")
    link(rel="stylesheet" href="/css/style.css")
    script(src="https://cdn.tailwindcss.com")
    style.
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; background: #f8fafc; color: #0f172a; }

      /* ── Nav ── */
      .lp-nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid #e5e7eb;
        padding: 0 1.75rem;
        height: 64px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .lp-brand { font-size: 1.35rem; font-weight: 800; letter-spacing: -0.03em; color: #0f172a; text-decoration: none; }
      .lp-brand span { color: #6366f1; }
      .lp-nav-links { display: flex; gap: 0.5rem; align-items: center; }
      .btn-ghost { padding: 0.45rem 1rem; border-radius: 8px; font-size: 0.875rem; font-weight: 500; color: #374151; text-decoration: none; transition: background 0.15s; }
      .btn-ghost:hover { background: #f1f5f9; }
      .btn-indigo { padding: 0.45rem 1.1rem; border-radius: 8px; font-size: 0.875rem; font-weight: 600; background: #6366f1; color: #fff; text-decoration: none; transition: background 0.15s; }
      .btn-indigo:hover { background: #4f46e5; }

      /* ── Hero ── */
      .hero {
        min-height: calc(100vh - 64px);
        display: flex; align-items: center; justify-content: center;
        text-align: center;
        padding: 4rem 1.5rem;
        background: linear-gradient(135deg, #eef2ff 0%, #f8fafc 50%, #fdf4ff 100%);
        position: relative; overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(99,102,241,0.12) 0%, transparent 70%);
        pointer-events: none;
      }
      .hero-inner { max-width: 720px; position: relative; }
      .hero-badge {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: #ede9fe; color: #4f46e5;
        font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em;
        padding: 0.3rem 0.85rem; border-radius: 999px;
        margin-bottom: 1.5rem;
      }
      .hero-title {
        font-size: clamp(2.2rem, 5vw, 3.6rem);
        font-weight: 800; line-height: 1.12;
        letter-spacing: -0.03em; color: #0f172a;
        margin-bottom: 1.25rem;
      }
      .hero-title span { color: #6366f1; }
      .hero-sub {
        font-size: clamp(1rem, 2.5vw, 1.15rem);
        color: #64748b; line-height: 1.7;
        max-width: 560px; margin: 0 auto 2.25rem;
      }
      .hero-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
      .hero-cta-primary {
        padding: 0.8rem 1.75rem; border-radius: 10px;
        background: #6366f1; color: #fff;
        font-size: 1rem; font-weight: 600; text-decoration: none;
        transition: background 0.15s, transform 0.1s;
        box-shadow: 0 4px 14px rgba(99,102,241,0.35);
      }
      .hero-cta-primary:hover { background: #4f46e5; transform: translateY(-1px); }
      .hero-cta-secondary {
        padding: 0.8rem 1.75rem; border-radius: 10px;
        background: #fff; color: #374151;
        font-size: 1rem; font-weight: 600; text-decoration: none;
        border: 1.5px solid #e5e7eb;
        transition: border-color 0.15s, transform 0.1s;
      }
      .hero-cta-secondary:hover { border-color: #6366f1; color: #6366f1; transform: translateY(-1px); }

      /* ── Stats strip ── */
      .stats-strip {
        background: #fff;
        border-top: 1px solid #f1f5f9;
        border-bottom: 1px solid #f1f5f9;
        padding: 2.5rem 1.5rem;
      }
      .stats-inner { max-width: 900px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 2rem 4rem; }
      .stat-item { text-align: center; }
      .stat-value { font-size: 2rem; font-weight: 800; color: #6366f1; letter-spacing: -0.03em; }
      .stat-label { font-size: 0.85rem; color: #64748b; margin-top: 0.2rem; font-weight: 500; }

      /* ── Section ── */
      .section { padding: 5rem 1.5rem; }
      .section-center { text-align: center; }
      .section-inner { max-width: 1040px; margin: 0 auto; }
      .section-eyebrow {
        display: inline-block;
        font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em;
        text-transform: uppercase; color: #6366f1;
        margin-bottom: 0.75rem;
      }
      .section-title {
        font-size: clamp(1.6rem, 3.5vw, 2.4rem);
        font-weight: 800; letter-spacing: -0.025em; color: #0f172a;
        margin-bottom: 0.9rem; line-height: 1.2;
      }
      .section-sub { font-size: 1rem; color: #64748b; max-width: 560px; margin: 0 auto; line-height: 1.7; }

      /* ── Features grid ── */
      .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1.25rem; margin-top: 3.5rem;
      }
      .feature-card {
        background: #fff; border: 1px solid #e5e7eb;
        border-radius: 16px; padding: 1.75rem 1.5rem;
        transition: box-shadow 0.2s, transform 0.15s;
      }
      .feature-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.08); transform: translateY(-3px); }
      .feature-icon {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; margin-bottom: 1rem;
      }
      .feature-title { font-size: 1rem; font-weight: 700; color: #0f172a; margin-bottom: 0.4rem; }
      .feature-desc { font-size: 0.875rem; color: #64748b; line-height: 1.6; }

      /* ── How it works ── */
      .steps { background: #fff; }
      .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2rem; margin-top: 3.5rem;
        position: relative;
      }
      .step-card { text-align: center; padding: 1rem; }
      .step-num {
        width: 52px; height: 52px; border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #818cf8);
        color: #fff; font-size: 1.2rem; font-weight: 800;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.25rem;
        box-shadow: 0 4px 14px rgba(99,102,241,0.3);
      }
      .step-title { font-size: 1rem; font-weight: 700; color: #0f172a; margin-bottom: 0.4rem; }
      .step-desc { font-size: 0.875rem; color: #64748b; line-height: 1.65; }

      /* ── Bonus highlight ── */
      .bonus-section { background: linear-gradient(135deg, #eef2ff, #fdf4ff); }
      .bonus-card {
        max-width: 720px; margin: 3rem auto 0;
        background: #fff; border: 1.5px solid #c7d2fe;
        border-radius: 20px; padding: 2.5rem 2rem;
        display: flex; align-items: flex-start; gap: 1.5rem;
        flex-wrap: wrap;
      }
      .bonus-icon-wrap {
        flex-shrink: 0;
        width: 64px; height: 64px; border-radius: 16px;
        background: linear-gradient(135deg, #6366f1, #818cf8);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.75rem;
        box-shadow: 0 6px 18px rgba(99,102,241,0.35);
      }
      .bonus-content { flex: 1; min-width: 200px; }
      .bonus-title { font-size: 1.25rem; font-weight: 800; color: #0f172a; margin-bottom: 0.5rem; }
      .bonus-desc { font-size: 0.9rem; color: #475569; line-height: 1.65; }
      .bonus-pill {
        display: inline-block; margin-top: 0.85rem;
        background: #ede9fe; color: #4f46e5;
        font-size: 0.8rem; font-weight: 700;
        padding: 0.3rem 0.85rem; border-radius: 999px;
      }

      /* ── CTA banner ── */
      .cta-banner {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: #fff; text-align: center;
        padding: 5rem 1.5rem;
      }
      .cta-title { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; letter-spacing: -0.025em; margin-bottom: 1rem; }
      .cta-sub { font-size: 1.05rem; opacity: 0.85; margin-bottom: 2rem; }
      .cta-btn {
        display: inline-block; padding: 0.85rem 2rem;
        background: #fff; color: #4f46e5;
        font-size: 1rem; font-weight: 700;
        border-radius: 10px; text-decoration: none;
        transition: transform 0.15s, box-shadow 0.15s;
        box-shadow: 0 4px 14px rgba(0,0,0,0.15);
      }
      .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }

      /* ── Footer ── */
      footer {
        background: #0f172a; color: #94a3b8;
        padding: 2.5rem 1.75rem;
        display: flex; flex-wrap: wrap;
        align-items: center; justify-content: space-between;
        gap: 1rem;
      }
      .footer-brand { font-size: 1.15rem; font-weight: 800; color: #fff; letter-spacing: -0.02em; }
      .footer-brand span { color: #818cf8; }
      .footer-copy { font-size: 0.8rem; }

  body
    //- ── Navigation ──────────────────────────────────────────────────────────
    nav.lp-nav
      a.lp-brand(href="/") Sav#[span ify]
      .lp-nav-links
        a.btn-ghost(href="/auth/login") Sign in
        a.btn-indigo(href="/auth/register") Get started

    //- ── Hero ────────────────────────────────────────────────────────────────
    section.hero
      .hero-inner
        .hero-badge
          span ✦
          | Smart savings, real rewards
        h1.hero-title
          | Save with purpose.
          br
          span Reach your goals faster.
        p.hero-sub
          | Savify helps you build consistent saving habits, track your progress, and rewards your discipline with a bonus at withdrawal.
        .hero-actions
          a.hero-cta-primary(href="/auth/register") Start saving for free
          a.hero-cta-secondary(href="/auth/login") Sign in

    //- ── Stats ───────────────────────────────────────────────────────────────
    .stats-strip
      .stats-inner
        .stat-item
          .stat-value Goal-based
          .stat-label Structured savings plans
        .stat-item
          .stat-value 3% Bonus
          .stat-label Consistency reward
        .stat-item
          .stat-value Secure
          .stat-label Bank-grade withdrawals
        .stat-item
          .stat-value Real-time
          .stat-label Progress tracking

    //- ── Features ────────────────────────────────────────────────────────────
    section.section.section-center
      .section-inner
        span.section-eyebrow Everything you need
        h2.section-title Built for disciplined savers
        p.section-sub Set goals, make contributions on your schedule, and watch your savings grow — all in one place.
        .features-grid
          .feature-card
            .feature-icon(style="background:#ede9fe;") 🎯
            .feature-title Goal Tracking
            .feature-desc Create savings goals with a target amount, time frame, and category. Track your progress with visual gauges.
          .feature-card
            .feature-icon(style="background:#dcfce7;") 💰
            .feature-title Flexible Contributions
            .feature-desc Save daily, weekly, or monthly — however suits your lifestyle. Every deposit is logged and visible.
          .feature-card
            .feature-icon(style="background:#fef9c3;") 🏆
            .feature-title Consistency Rewards
            .feature-desc Earn a 3% loyalty bonus when you save consistently across 75% or more of your expected saving periods.
          .feature-card
            .feature-icon(style="background:#fee2e2;") 🏦
            .feature-title Secure Withdrawals
            .feature-desc Link your bank accounts and withdraw completed goals directly to your preferred account — safely and transparently.

    //- ── How it works ────────────────────────────────────────────────────────
    section.section.steps.section-center
      .section-inner
        span.section-eyebrow Simple process
        h2.section-title How Savify works
        p.section-sub Three easy steps stand between you and your savings goal.
        .steps-grid
          .step-card
            .step-num 1
            .step-title Create a goal
            .step-desc Choose a name, target amount, saving frequency, and end date. Savify calculates your plan automatically.
          .step-card
            .step-num 2
            .step-title Make contributions
            .step-desc Add deposits whenever you like using your chosen payment method. Your progress updates in real time.
          .step-card
            .step-num 3
            .step-title Withdraw & get rewarded
            .step-desc Once your goal is complete, withdraw to your bank account. Consistent savers earn a 3% bonus on top.

    //- ── Bonus highlight ─────────────────────────────────────────────────────
    section.section.bonus-section.section-center
      .section-inner
        span.section-eyebrow Loyalty reward
        h2.section-title Consistency pays — literally
        p.section-sub We believe great saving habits deserve recognition.
        .bonus-card
          .bonus-icon-wrap 🎁
          .bonus-content
            .bonus-title Earn a 3% consistency bonus
            .bonus-desc
              | When you save in at least 75% of your expected contribution periods — whether that's daily, weekly, or monthly —
              | Savify automatically adds a
              strong  3% bonus
              |  to your final withdrawal amount. No action needed; it's calculated and applied for you at withdrawal time.
            span.bonus-pill Automatically applied at withdrawal

    //- ── CTA ─────────────────────────────────────────────────────────────────
    section.cta-banner
      h2.cta-title Ready to start saving smarter?
      p.cta-sub Join Savify today and turn your savings goals into reality.
      a.cta-btn(href="/auth/register") Create your free account

    //- ── Footer ──────────────────────────────────────────────────────────────
    footer
      span.footer-brand Sav#[span ify]
      span.footer-copy &copy; 2026 Savify. All rights reserved.
